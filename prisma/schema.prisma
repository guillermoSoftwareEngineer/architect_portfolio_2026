generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id        String   @id @default(cuid())
  slug      String   @unique
  views     Int      @default(0)
  createdAt DateTime @default(now())
  
  @@index([slug])
}

model Contact {
  id        String   @id @default(cuid())
  email     String
  message   String
  createdAt DateTime @default(now())
  
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  
  @@index([email])
}
